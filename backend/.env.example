# Copy this file to `.env` and fill in real values for local development.
# In production (Render) these are set as service environment variables.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Leave unset locally to use SQLite. Set to a Postgres URL in production:
# DATABASE_URL=postgres://user:password@host:5432/dbname
# DATABASE_SSL_REQUIRE=True

BASE_CURRENCY=INR

# Free Groq API key from https://console.groq.com/keys (NL balance-query feature).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
